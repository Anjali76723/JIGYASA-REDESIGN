# Port for the Express server to run on
PORT=5000

# URL of your frontend (for CORS restriction in production)
FRONTEND_URL=http://localhost:5173

# SMTP Server details (e.g., smtp.gmail.com, smtp.mailgun.org, etc.)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
# Set to true for port 465, false for 587 or 25
EMAIL_SECURE=false

# SMTP Auth credentials
# IMPORTANT: For Gmail, use an App Password (do not use your actual account password)
EMAIL_USER=your_smtp_email@gmail.com
EMAIL_PASS=your_smtp_app_password

# Destination Email where contact inquiries should be sent
RECEIVER_EMAIL=receiver_email@gmail.com
